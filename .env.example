# =============================================
# BACKEND (Django)
# =============================================

# Django
SECRET_KEY=dev-secret-key-change-in-production-12345678
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos PostgreSQL
DATABASE_URL=postgres://ecoe_user:ecoe_pass@localhost:5432/ecoe_db
POSTGRES_DB=ecoe_db
POSTGRES_USER=ecoe_user
POSTGRES_PASSWORD=ecoe_pass

# CORS (frontend origins permitidos)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT
# ACCESS_TOKEN_LIFETIME_MINUTES=60
# REFRESH_TOKEN_LIFETIME_DAYS=7

# =============================================
# FRONTEND (Vite/React)
# =============================================

VITE_API_URL=http://localhost:8000/api/v1

# =============================================
# PRODUCCIÓN (Render)
# =============================================
# SECRET_KEY=<generar con: python -c "import secrets; print(secrets.token_urlsafe(50))">
# DJANGO_SETTINGS_MODULE=config.settings.prod
# DATABASE_URL=<postgres URL de Render>
# ALLOWED_HOSTS=<tu-app>.onrender.com
# CORS_ALLOWED_ORIGINS=https://<tu-frontend>.onrender.com
# VITE_API_URL=https://<tu-backend>.onrender.com/api/v1
